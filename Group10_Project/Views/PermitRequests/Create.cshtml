@model Group10_Project.Models.PermitRequest

@{
    ViewBag.Title = "Create Permit Request";
}

<h2>Create Permit Request</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4>Permit Request</h4>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            @Html.LabelFor(model => model.activityDescription, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.activityDescription, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                @Html.ValidationMessageFor(model => model.activityDescription, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.activityStartDate, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.activityStartDate, new
           {
               htmlAttributes = new
               {
                   @class = "form-control",
                   type = "date",
                   required = "required",
                   min = DateTime.Now.ToString("yyyy-MM-dd")
               }
           })
                @Html.ValidationMessageFor(model => model.activityStartDate, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.activityDuration, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.activityDuration, new
           {
               htmlAttributes = new
               {
                   @class = "form-control",
                   type = "date",
                   required = "required",
                   min = DateTime.Now.ToString("yyyy-MM-dd")
               }
           })
                @Html.ValidationMessageFor(model => model.activityDuration, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.permitTypeID, "Permit Type", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("permitTypeID", null, "-- Select Permit Type --", new { @class = "form-control", required = "required" })
                @Html.ValidationMessageFor(model => model.permitTypeID, "", new { @class = "text-danger" })
            </div>
        </div>

        <p>

        </p>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Submit Permit Request" class="btn btn-primary" />
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("Back to Dashboard", "Dashboard", "REs")
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}