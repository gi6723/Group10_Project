@model Group10_Project.Models.Payment

@{
    ViewBag.Title = "Pay Fee";
}

<h2>Pay Permit Fee</h2>

<div class="panel panel-default">
    <div class="panel-heading">
        <strong>Permit Request Information</strong>
    </div>
    <div class="panel-body">
        <p><strong>Request No:</strong> @ViewBag.RequestId</p>
        <p><strong>Permit:</strong> @ViewBag.PermitName</p>
        <p><strong>Fee:</strong> @String.Format("{0:C}", ViewBag.PermitFee)</p>
    </div>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @Html.Hidden("requestId", (string)ViewBag.RequestId)

    <div class="form-horizontal">
        <h4>Payment Information</h4>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })


        <div class="form-group">
            @Html.LabelFor(model => model.paymentMethod, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.paymentMethod,
                         new SelectList(new[]
                         {
                        "Visa",
                        "MasterCard",
                        "PayPal"
                         }),
                         "-- Select Payment Method --",
                         new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.paymentMethod, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.last4CardDigit, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.last4CardDigit, new { htmlAttributes = new { @class = "form-control", placeholder = "Last 4 digits only" } })
                @Html.ValidationMessageFor(model => model.last4CardDigit, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.cardHolderName, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.cardHolderName, new { htmlAttributes = new { @class = "form-control", placeholder = "Cardholder Name" } })
                @Html.ValidationMessageFor(model => model.cardHolderName, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Submit Payment" class="btn btn-success" />
                @Html.ActionLink("Cancel", "Dashboard", "REs", null, new { @class = "btn btn-default" })
            </div>
        </div>
    </div>
}