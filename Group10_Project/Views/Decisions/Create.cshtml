@model Group10_Project.Models.Decision

@{
    ViewBag.Title = "Review Application";
}

<h2>Review Submitted Application</h2>

<div class="panel panel-default">
    <div class="panel-heading">
        <strong>Application Information</strong>
    </div>
    <div class="panel-body">
        <p><strong>Request No:</strong> @ViewBag.RequestId</p>
        <p><strong>Permit:</strong> @ViewBag.PermitName</p>
        <p><strong>Regulated Entity:</strong> @ViewBag.REName</p>
        <p><strong>Reviewing EO:</strong> @ViewBag.EOName</p>
    </div>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @Html.Hidden("requestId", (string)ViewBag.RequestId)

    <div class="form-horizontal">
        <h4>Decision</h4>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            @Html.LabelFor(model => model.finalDecision, "Final Decision", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.finalDecision,
                         new SelectList(new[]
                         {
                        "Approved",
                        "Rejected"
                         }),
                         "-- Select Decision --",
                         new { @class = "form-control", required = "required" })
                @Html.ValidationMessageFor(model => model.finalDecision, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.description, "Decision Notes", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextAreaFor(model => model.description, new { @class = "form-control", rows = 4, placeholder = "Enter approval or rejection notes", required = "required" })
                @Html.ValidationMessageFor(model => model.description, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Submit Decision" class="btn btn-primary" />
                @Html.ActionLink("Cancel", "Dashboard", "EO", null, new { @class = "btn btn-default" })
            </div>
        </div>
    </div>
}