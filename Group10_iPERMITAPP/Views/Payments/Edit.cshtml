                <div class="checkbox">
                    @Html.EditorFor(model => model.paymentApproved)
                    @Html.ValidationMessageFor(model => model.paymentApproved, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
