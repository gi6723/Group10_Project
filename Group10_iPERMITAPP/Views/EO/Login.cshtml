@{
    ViewBag.Title = "EO Login";
}

<h2>Environmental Officer Login</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />

        <div class="form-group">
            <label class="control-label col-md-2">EO ID</label>
            <div class="col-md-10">
                <input type="text" name="id" class="form-control" placeholder="Enter EO ID" />
            </div>
        </div>

        <div class="form-group">
            <label class="control-label col-md-2">Password</label>
            <div class="col-md-10">
                <input type="password" name="password" class="form-control" placeholder="Enter Password" />
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Login" class="btn btn-primary" />
                @Html.Raw(" ")
                @Html.ActionLink("Change Password", "ChangePassword", "EO", null, new { @class = "btn btn-warning" })
            </div>
        </div>
    </div>
}